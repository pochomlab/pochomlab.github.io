---
// 目次コンポーネント
const { title, items = [] } = Astro.props;
---

<section id="lights" class="py-20 bg-neutral-100 dark:bg-slate-950">
  <div class="container mx-auto max-w-5xl">
    {title && <h2 class="text-2xl font-serif mb-10 text-center">{title}</h2>}

    {
      items && items.length ? (
        <div class="mx-auto w-fit">
          <ol class="space-y-3 text-lg">
            {items.map(({ label, description }) => (
              <li class="grid grid-cols-[max-content_auto] items-baseline gap-x-2 text-left">
                <span class="whitespace-nowrap font-mono text-neutral-400 dark:text-neutral-500">
                  {label}
                </span>
                <span>{description}</span>
              </li>
            ))}
          </ol>
        </div>
      ) : (
        <p class="text-center text-sm opacity-80">No items to display.</p>
      )
    }
  </div>
</section>

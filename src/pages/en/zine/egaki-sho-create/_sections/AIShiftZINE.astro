---
const data = {
  eyebrow: 'AI<<ZINE (read: AI-ZINE)',
  title: 'From a ZINE to read, to a ZINE to use',
  body: [
    'This ZINE series is not only something to read, but also a “thought plugin” that can be shared with generative AI and used as your own personal creative studio.',
    'At PochomLab, we call this idea AI<<ZINE — a concept built on that way of using a ZINE.',
  ],
};
---

<section id="ai-zine" class="scroll-mt-20 py-12 md:py-16 bg-slate-950 text-neutral-100">
  <div class="container mx-auto max-w-4xl px-4">
    <div class="mx-auto max-w-3xl text-center">
      <p class="text-sm md:text-base tracking-[0.18em] text-cyan-200/80">
        {data.eyebrow}
      </p>

      <h2 class="mt-4 font-serif text-2xl md:text-3xl tracking-tight">
        {data.title}
      </h2>

      <div class="mx-auto mt-6 h-px w-20 bg-white/15"></div>

      <div class="mt-8 space-y-4 text-sm md:text-[15px] leading-relaxed text-neutral-200">
        {data.body.map((line) => (
          <p>{line}</p>
        ))}
      </div>
    </div>
  </div>
</section>